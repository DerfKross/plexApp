PORT=3747
HOST=0.0.0.0

# qBittorrent Web UI settings. Enable Web UI in qBittorrent first.
QBITTORRENT_URL=http://127.0.0.1:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin

# Completed download folders. qBittorrent receives one of these as savepath.
MOVIE_SAVE_PATH=D:\Media\Movies
TV_SAVE_PATH=D:\Media\TV Shows

# Plex settings. PLEX_LIBRARY_SECTION_ID can be Movies or TV library section id.
PLEX_URL=http://127.0.0.1:32400
PLEX_TOKEN=
PLEX_MOVIE_SECTION_ID=1
PLEX_TV_SECTION_ID=2

# Optional: comma-separated Torznab/Newznab-compatible legal indexers.
# Example: https://example.local/api?t=search&apikey=KEY
TORZNAB_SOURCES=

# Optional: comma-separated RSS feeds from approved legal torrent sources.
# The app filters these feeds by title and uses .torrent enclosures or magnet links.
TORRENT_RSS_SOURCES=

# Optional: comma-separated labels for RSS buttons. Order must match TORRENT_RSS_SOURCES.
TORRENT_RSS_LABELS=

# Optional: comma-separated RSS search URL templates.
# Search replaces {query} or {keyword} with the user's search text.
TORRENT_RSS_SEARCH_SOURCES=

# Optional: comma-separated labels for RSS search templates.
TORRENT_RSS_SEARCH_LABELS=

# Set to false if you want RSS/Torznab sources only.
ENABLE_INTERNET_ARCHIVE=true

# Max RSS items to read from each feed when browsing.
RSS_ITEMS_PER_FEED=100

# Safety gate for direct torrent/magnet URLs entered in the UI.
ALLOW_DIRECT_TORRENT_URLS=true
